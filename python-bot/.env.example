# Capital.com Demo API credentials
CAPITAL_EMAIL=your-email@example.com
CAPITAL_PASSWORD=your-password
CAPITAL_API_KEY=your-api-key

# Demo API URL (change to https://api-capital.backend-capital.com for live)
CAPITAL_API_URL=https://demo-api-capital.backend-capital.com

# Risk settings
RISK_PER_TRADE=0.01
MAX_OPEN_POSITIONS=5

# Strategy settings
EMA_FAST=9
EMA_SLOW=21
EMA_TREND=50
ATR_PERIOD=14
ATR_SL_MULTIPLIER=2.0
ATR_TP_MULTIPLIER=3.0
CANDLE_TIMEFRAME=MINUTE_15
SCAN_INTERVAL_SECONDS=60
