# Bybit Testnet API credentials
BYBIT_API_KEY=your-api-key
BYBIT_API_SECRET=your-api-secret

# Testnet (change to https://api.bybit.com for mainnet)
BYBIT_BASE_URL=https://api-testnet.bybit.com

# Trading pairs (comma-separated)
WATCHLIST=BTCUSDT,ETHUSDT,SOLUSDT,XRPUSDT

# Risk settings
RISK_PER_TRADE=0.01
MAX_OPEN_POSITIONS=5
LEVERAGE=10

# Strategy settings
EMA_FAST=9
EMA_SLOW=21
RSI_PERIOD=14
CANDLE_INTERVAL=15

# SL settings
INITIAL_SL_PCT=0.015
TRAILING_STEP_PCT=0.01

# Bybit fees (taker)
TAKER_FEE_PCT=0.00055

# Scan interval
SCAN_INTERVAL_SECONDS=5
