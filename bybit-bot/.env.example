# Bitget API credentials (Demo trading)
# Create Demo API keys: Login → Switch to Demo mode → Personal Center → API Key Management
BITGET_API_KEY=your-api-key
BITGET_API_SECRET=your-api-secret
BITGET_API_PASSPHRASE=your-api-passphrase

# Demo trading (paper trading) — set to 1 for demo, 0 for live
BITGET_DEMO=1

# Trading pairs (comma-separated, USDT perpetuals)
WATCHLIST=BTCUSDT,ETHUSDT,SOLUSDT,XRPUSDT

# Risk settings
RISK_PER_TRADE=0.01
MAX_OPEN_POSITIONS=5
LEVERAGE=10

# Strategy settings
EMA_FAST=9
EMA_SLOW=21
RSI_PERIOD=14
CANDLE_INTERVAL=15

# SL settings
INITIAL_SL_PCT=0.015
TRAILING_STEP_PCT=0.01

# Bitget fees (taker)
TAKER_FEE_PCT=0.0006

# Scan interval
SCAN_INTERVAL_SECONDS=5
